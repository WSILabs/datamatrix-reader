# Archives / scratch
*.tar.gz

# Large public datasets (multi-GB; not for version control)
corpus/public/

# BarBeR-derived images (regenerable via tools/import_barber.py); keep labels.csv
corpus/barber/images/

# Domain reference images (web/marketing; used to calibrate synth, not tracked)
corpus/pathology_samples/

# Real Grundium WSI slide labels — real clinical captures; kept local, not for version control.
corpus/wsi_labels/

# No-barcode labels moved aside by tools/label_gt.py — also kept local.
corpus/wsi_labels_removed/

# Raw YOLO training weights + the pretrained base (heavy, intermediate; regenerable via
# tools/train_yolo.py). The SHIPPED detector is the exported ONNX under
# src/datamatrix_reader/models/, which IS committed (small; works out-of-the-box on clone).
*.pt

