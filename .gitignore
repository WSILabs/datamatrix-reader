*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Compiled cffi shim (built per-platform via `python -m dmtxslide._build_dmtx`)
*.so
*.o
*.dylib
# generated cffi C source
**/_dmtx.c

# Benchmark run outputs (regenerated; baselines diffed via bench.report)
runs/

# Archives / scratch
*.tar.gz

# Large public datasets (multi-GB; not for version control)
dmtxslide/corpus/public/
corpus/public/

# BarBeR-derived images (regenerable via tools/import_barber.py); keep labels.csv
dmtxslide/corpus/barber/images/
corpus/barber/images/

# Domain reference images (web/marketing; used to calibrate synth, not tracked)
dmtxslide/corpus/pathology_samples/
corpus/pathology_samples/

# Real Grundium WSI slide labels — PHI (filenames contain accession numbers). NEVER commit.
dmtxslide/corpus/wsi_labels/
corpus/wsi_labels/

# No-barcode labels moved aside by tools/label_gt.py (PHI). NEVER commit.
dmtxslide/corpus/wsi_labels_removed/
corpus/wsi_labels_removed/

